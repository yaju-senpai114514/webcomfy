# 첫 실행 시 servers.json의 'default' 서버로 이관되는 초기 ComfyUI 주소/서명 키 이름.
# 이후 서버 추가/수정은 UI의 "ComfyUI 서버" 패널에서.
# 키페어 생성: uv run scripts/gen_keypair.py <name>  →  keys/<name>.key / keys/<name>.pub
COMFY_BASE_URL="http://remote_comfy_server.ts.net:8188"
WEBCOMFY_KEY_NAME="orchestrator"

# webcomfy UI 바인딩 (뷰어는 PORT+1)
PORT=58000
HOST=localhost

# 로컬 모델 저장소 위치 (기본: <repo>/local_models)
# LOCAL_MODELS_DIR=/path/to/local_models
